FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /srv/image-api
COPY pyproject.toml README.md LICENSE NOTICE.md ./
COPY licenses ./licenses
COPY src ./src
RUN pip install --no-cache-dir .
RUN useradd --create-home --uid 10001 image-api && mkdir -p /state && chown -R image-api:image-api /state
USER image-api
EXPOSE 9001
CMD ["uvicorn", "image_api_workers.fake:app", "--host", "0.0.0.0", "--port", "9001"]
