FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /srv/image-api
COPY pyproject.toml README.md LICENSE NOTICE.md ./
COPY licenses ./licenses
COPY src ./src
RUN pip install --no-cache-dir .
RUN groupadd --gid 10001 image-api && useradd --create-home --uid 10001 --gid 10001 image-api && mkdir -p /state && chown -R 10001:10001 /state
USER 10001:10001
EXPOSE 9001
CMD ["uvicorn", "image_api_workers.fake:app", "--host", "0.0.0.0", "--port", "9001"]
